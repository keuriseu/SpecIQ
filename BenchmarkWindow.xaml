<Window x:Class="SpecIQ.BenchmarkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SpecIQ — Benchmarks"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        ShowInTaskbar="True"
        MouseLeftButtonDown="TitleBar_MouseDown">

    <Window.Resources>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="Foreground"  Value="#70FFFFFF"/>
        </Style>
        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Foreground"  Value="White"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"     Value="20,9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#EE1A1A2E" CornerRadius="14" Width="340">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" Opacity="0.5" ShadowDepth="4"/>
        </Border.Effect>

        <StackPanel>

            <!-- Title bar -->
            <Grid Margin="20,16,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="GEEKBENCH 6" FontFamily="Segoe UI" FontSize="11"
                               FontWeight="Bold" Foreground="#80FFFFFF"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Click="Close_Click"
                        Background="Transparent" Foreground="#60FFFFFF"
                        FontSize="14" Padding="8,4" Cursor="Hand" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#20FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <Border Height="1" Background="#15FFFFFF" Margin="0,12,0,0"/>

            <!-- ── Checking panel ── -->
            <StackPanel x:Name="CheckingPanel" Margin="20,20,20,20" HorizontalAlignment="Center">
                <TextBlock Text="Checking…" Style="{StaticResource Label}"
                           HorizontalAlignment="Center" FontSize="12"/>
            </StackPanel>

            <!-- ── Ready panel ── -->
            <StackPanel x:Name="ReadyPanel" Visibility="Collapsed" Margin="20,16,20,20">
                <TextBlock x:Name="StatusText" Text="—" Style="{StaticResource Label}"
                           HorizontalAlignment="Center" FontSize="11" Margin="0,0,0,16"/>

                <StackPanel x:Name="InstallRow" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,0,0,0">
                    <Button x:Name="InstallBtn" Content="Install" Click="Install_Click"
                            Background="#3B82F6" Style="{StaticResource Btn}" Margin="0,0,8,0"/>
                </StackPanel>

                <StackPanel x:Name="RunRow" Orientation="Horizontal"
                            HorizontalAlignment="Center" Visibility="Collapsed">
                    <Button x:Name="UpdateBtn" Content="Update" Click="Install_Click"
                            Background="#30FFFFFF" Style="{StaticResource Btn}" Margin="0,0,8,0"
                            Visibility="Collapsed"/>
                    <Button Content="Run CPU Benchmark" Click="RunBenchmark_Click"
                            Background="#3B82F6" Style="{StaticResource Btn}"/>
                </StackPanel>
            </StackPanel>

            <!-- ── Installing panel ── -->
            <StackPanel x:Name="InstallingPanel" Visibility="Collapsed" Margin="20,16,20,20">
                <TextBlock x:Name="InstallStatusText" Text="Downloading…"
                           Style="{StaticResource Label}" HorizontalAlignment="Center"
                           FontSize="12" Margin="0,0,0,10"/>
                <Border Background="#20FFFFFF" CornerRadius="4" Height="6" Margin="0,0,0,4">
                    <Border x:Name="InstallProgressBar" Background="#3B82F6" CornerRadius="4"
                            HorizontalAlignment="Left" Width="0"/>
                </Border>
                <TextBlock x:Name="InstallPctText" Text="0%" Style="{StaticResource Label}"
                           HorizontalAlignment="Center" FontSize="10"/>
            </StackPanel>

            <!-- ── Running panel ── -->
            <StackPanel x:Name="RunningPanel" Visibility="Collapsed" Margin="20,16,20,20">
                <TextBlock x:Name="RunPhaseText" Text="Running Single-Core…"
                           Style="{StaticResource Value}" HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                <TextBlock x:Name="RunWorkloadText" Text="—" Style="{StaticResource Label}"
                           HorizontalAlignment="Center" FontSize="11" Margin="0,0,0,14"/>

                <!-- Indeterminate progress dots -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Ellipse x:Name="Dot1" Width="6" Height="6" Fill="#3B82F6" Margin="4,0"/>
                    <Ellipse x:Name="Dot2" Width="6" Height="6" Fill="#3B82F6" Margin="4,0" Opacity="0.5"/>
                    <Ellipse x:Name="Dot3" Width="6" Height="6" Fill="#3B82F6" Margin="4,0" Opacity="0.25"/>
                </StackPanel>

                <Button Content="Cancel" Click="Cancel_Click"
                        Background="#30FFFFFF" Style="{StaticResource Btn}"
                        HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- ── Result panel ── -->
            <StackPanel x:Name="ResultPanel" Visibility="Collapsed" Margin="20,16,20,20">
                <TextBlock Text="CPU BENCHMARK RESULTS" Style="{StaticResource Label}"
                           HorizontalAlignment="Center" Margin="0,0,0,14"/>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Single-Core" Style="{StaticResource Label}"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="ResultSingle" Text="—"
                               FontSize="22" FontWeight="Bold" FontFamily="Segoe UI"
                               Foreground="White"/>
                </Grid>

                <Border Height="1" Background="#15FFFFFF" Margin="0,6"/>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Multi-Core" Style="{StaticResource Label}"
                               FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="ResultMulti" Text="—"
                               FontSize="22" FontWeight="Bold" FontFamily="Segoe UI"
                               Foreground="#60A5FA"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Run Again" Click="RunBenchmark_Click"
                            Background="#30FFFFFF" Style="{StaticResource Btn}"/>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
