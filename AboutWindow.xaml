<Window x:Class="SpecIQ.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About SpecIQ"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        ShowInTaskbar="False">

    <Border Background="#F01A1A2E" CornerRadius="14" Padding="32,28" MinWidth="300">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" Opacity="0.5" ShadowDepth="4"/>
        </Border.Effect>

        <StackPanel>
            <!-- App name -->
            <TextBlock Text="SpecIQ" FontSize="26" FontWeight="Bold"
                       FontFamily="Segoe UI" Foreground="White"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="System Monitor Overlay" FontSize="11"
                       FontFamily="Segoe UI" Foreground="#80FFFFFF"
                       HorizontalAlignment="Center" Margin="0,2,0,16"/>

            <!-- Version -->
            <Border Background="#15FFFFFF" CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Version" Foreground="#80FFFFFF"
                               FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="VersionText" Text="1.0.0"
                               Foreground="White" FontSize="11" FontWeight="SemiBold"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Runtime -->
            <Border Background="#15FFFFFF" CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Runtime" Foreground="#80FFFFFF"
                               FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="RuntimeText" Text=".NET 9.0"
                               Foreground="White" FontSize="11" FontWeight="SemiBold"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Author -->
            <Border Background="#15FFFFFF" CornerRadius="8" Padding="14,10" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Author" Foreground="#80FFFFFF"
                               FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="keuriseu" Foreground="White"
                               FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Description -->
            <TextBlock Text="Lightweight always-on-top overlay displaying real-time battery, CPU, RAM, GPU, and network stats."
                       FontSize="10.5" FontFamily="Segoe UI" Foreground="#60FFFFFF"
                       TextWrapping="Wrap" TextAlignment="Center"
                       MaxWidth="260" Margin="0,0,0,20"/>

            <!-- Close button -->
            <Button Content="Close" Click="Close_Click"
                    HorizontalAlignment="Center" Cursor="Hand"
                    FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                    Foreground="White" Background="#30FFFFFF"
                    Padding="24,8" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#50FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Border>
</Window>
