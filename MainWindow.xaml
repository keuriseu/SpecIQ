<Window x:Class="SpecIQ.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SpecIQ"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#80FFFFFF"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
        <Style x:Key="IconStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#80FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI Symbol, Segoe MDL2 Assets"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="20"/>
        </Style>
        <Style x:Key="SeparatorStyle" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="#20FFFFFF"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style x:Key="BarBackground" TargetType="Border">
            <Setter Property="Background" Value="#20FFFFFF"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Height" Value="3"/>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Background="#CC1A1A2E"
            CornerRadius="12"
            Padding="16,12"
            MinWidth="200">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.4" ShadowDepth="2"/>
        </Border.Effect>

        <StackPanel x:Name="ContentPanel">

            <!-- DateTime -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock x:Name="TimeText" Text="12:00"
                           FontSize="20" FontWeight="Bold" FontFamily="Segoe UI"
                           Foreground="White" VerticalAlignment="Bottom"/>
                <TextBlock x:Name="DateText" Text="Mon, Jan 1"
                           FontSize="10" FontFamily="Segoe UI"
                           Foreground="#80FFFFFF" VerticalAlignment="Bottom"
                           Margin="8,0,0,2"/>
            </StackPanel>

            <Border Style="{StaticResource SeparatorStyle}"/>

            <!-- Battery -->
            <Grid Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#xE996;" Style="{StaticResource IconStyle}"
                           FontFamily="Segoe MDL2 Assets" x:Name="BatteryIcon"/>
                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                    <TextBlock Text="BATTERY" Style="{StaticResource LabelStyle}" FontSize="9"/>
                    <Grid>
                        <Border Style="{StaticResource BarBackground}"/>
                        <Border x:Name="BatteryBar" Background="#4ADE80" CornerRadius="2"
                                Height="3" HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                </StackPanel>
                <TextBlock Grid.Column="2" x:Name="BatteryText" Text="--%" Style="{StaticResource ValueStyle}" Margin="10,0,0,0"/>
            </Grid>

            <Border Style="{StaticResource SeparatorStyle}"/>

            <!-- CPU -->
            <Grid Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#xE950;" Style="{StaticResource IconStyle}"
                           FontFamily="Segoe MDL2 Assets"/>
                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                    <TextBlock Text="CPU" Style="{StaticResource LabelStyle}" FontSize="9"/>
                    <Grid>
                        <Border Style="{StaticResource BarBackground}"/>
                        <Border x:Name="CpuBar" Background="#60A5FA" CornerRadius="2"
                                Height="3" HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                </StackPanel>
                <TextBlock Grid.Column="2" x:Name="CpuText" Text="--%" Style="{StaticResource ValueStyle}" Margin="10,0,0,0"/>
            </Grid>

            <Border Style="{StaticResource SeparatorStyle}"/>

            <!-- RAM -->
            <Grid Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#xE964;" Style="{StaticResource IconStyle}"
                           FontFamily="Segoe MDL2 Assets"/>
                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                    <TextBlock Text="RAM" Style="{StaticResource LabelStyle}" FontSize="9"/>
                    <Grid>
                        <Border Style="{StaticResource BarBackground}"/>
                        <Border x:Name="RamBar" Background="#C084FC" CornerRadius="2"
                                Height="3" HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                </StackPanel>
                <TextBlock Grid.Column="2" x:Name="RamText" Text="-- / -- GB" Style="{StaticResource ValueStyle}" Margin="10,0,0,0"/>
            </Grid>

            <Border Style="{StaticResource SeparatorStyle}"/>

            <!-- GPU -->
            <Grid Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#xE7F4;" Style="{StaticResource IconStyle}"
                           FontFamily="Segoe MDL2 Assets"/>
                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                    <TextBlock Text="GPU" Style="{StaticResource LabelStyle}" FontSize="9"/>
                    <Grid>
                        <Border Style="{StaticResource BarBackground}"/>
                        <Border x:Name="GpuBar" Background="#FB923C" CornerRadius="2"
                                Height="3" HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                </StackPanel>
                <TextBlock Grid.Column="2" x:Name="GpuText" Text="--%" Style="{StaticResource ValueStyle}" Margin="10,0,0,0"/>
            </Grid>

            <Border Style="{StaticResource SeparatorStyle}"/>

            <!-- NPU -->
            <Grid Margin="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#xE9D2;" Style="{StaticResource IconStyle}"
                           FontFamily="Segoe MDL2 Assets"/>
                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                    <TextBlock Text="NPU" Style="{StaticResource LabelStyle}" FontSize="9"/>
                    <Grid>
                        <Border Style="{StaticResource BarBackground}"/>
                        <Border x:Name="NpuBar" Background="#F472B6" CornerRadius="2"
                                Height="3" HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                </StackPanel>
                <TextBlock Grid.Column="2" x:Name="NpuText" Text="--%" Style="{StaticResource ValueStyle}" Margin="10,0,0,0"/>
            </Grid>

            <Border Style="{StaticResource SeparatorStyle}"/>

            <!-- Network -->
            <Grid Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#xE839;" Style="{StaticResource IconStyle}"
                           FontFamily="Segoe MDL2 Assets" x:Name="NetworkIcon"/>
                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                    <TextBlock Text="NETWORK" Style="{StaticResource LabelStyle}" FontSize="9"/>
                    <TextBlock x:Name="NetworkName" Text="--" Style="{StaticResource LabelStyle}"
                               FontSize="10" Foreground="#B0FFFFFF"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="NetworkUpText" Text="-- KB/s" Style="{StaticResource ValueStyle}" FontSize="10" Foreground="#80FFFFFF"/>
                    <TextBlock x:Name="NetworkDownText" Text="-- KB/s" Style="{StaticResource ValueStyle}" FontSize="10"/>
                </StackPanel>
            </Grid>

        </StackPanel>
    </Border>
</Window>
